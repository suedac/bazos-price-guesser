                    },
                    "price": {
                        "label": "Price",
                        "format": "text"
                    },
                    "location": {
                        "label": "Location",
                        "format": "text"
                    },
                    "listingUrl": {
                        "label": "Listing URL",
                        "format": "link"
                    }
                }
            }
        }
    }
